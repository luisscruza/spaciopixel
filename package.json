{
  "name": "spaciopixel",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/realtime",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web -- --host 0.0.0.0",
    "dev:realtime": "npm run dev --workspace apps/realtime",
    "dev:api": "composer run dev --working-dir=apps/api",
    "build:web": "npm run build --workspace apps/web",
    "build:realtime": "npm run build --workspace apps/realtime"
  }
}
